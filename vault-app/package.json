{
  "name": "vault",
  "version": "1.0.0",
  "description": "Visual Asset Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.vault.visuallibrary",
    "productName": "Vault",
    "copyright": "Copyright © 2026",
    "afterSign": "./afterSign.js",
    "directories": {
      "output": "../dist"
    },
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "dmg", "arch": ["x64"] }
      ],
      "minimumSystemVersion": "12.0",
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Vault",
      "backgroundColor": "#060606",
      "window": { "width": 540, "height": 420 },
      "contents": [
        { "x": 150, "y": 160, "type": "file" },
        { "x": 390, "y": 160, "type": "link", "path": "/Applications" },
        { "x": 270, "y": 330, "type": "file", "path": "/tmp/HOW TO OPEN.txt" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "afterSign.js"
    ],
    "extraResources": [
      { "from": "../vault.html", "to": "vault.html" }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  }
}
